class ZimjiGUI:
    def __init__(self, master):
        self.master = master
        self.master.title("Zimji CPU Debugger")
        self.cpu_data = Cpu()
        self.decoder = Cli()

        

        # Create UI elements
        self.create_widgets()

    def create_widgets(self):
        #CPU status frame
        self.status_widget = Widget_CPU_Status(self.master)
        self.status_widget.grid(row=0, column=0, padx=10, pady=10, sticky="n")


        # PC Label
        #self.pc_label = tk.Label(self.status_frame, text="Program Counter: ")
        #self.pc_label.grid(row=0, column=0, sticky="w")

        # Instruction Label
        #self.instr_label = tk.Label(self.status_frame, text="Instruction: ")
        #self.instr_label.grid(row=1, column=0, sticky="w")

        # Registers Frame
        self.reg_frame = tk.Frame(self.master)
        self.reg_frame.grid(row=0, column=1, sticky="w")
        self.reg_labels = {}

    def update_cpu_data(self, console_output):
        pc, instr, registers = self.decoder.decode(console_output)
        self.cpu_data.pc = pc
        self.cpu_data.instruction = instr
        self.cpu_data.registers = registers

        # Update UI
        #self.pc_label.config(text=f"Program Counter: {pc}")
        #self.instr_label.config(text=f"Instruction: {instr}")

        # Update Registers Display
        for reg, val in registers.items():
            if reg not in self.reg_labels:
                label = tk.Label(self.reg_frame, text=f"{reg}: {val}")
                label.pack(anchor="w")
                self.reg_labels[reg] = label
            else:
                self.reg_labels[reg].config(text=f"{reg}: {val}")


